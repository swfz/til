  },
  "scripts": {
    "build": "gatsby build",
    "dev": "NODE_ENV=development gatsby develop",
    "lint:md": "textlint content/blog",
    "lint:es": "eslint -c ./eslint.config.mjs 'src/**/*.{js,ts,tsx}' '*.{ts,js,tsx}' ",
    "lint:format": "prettier --check \"**/*.{js,ts,jsx,tsx,json}\"",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,json}\"",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "vitest run",
    "build:fts-sql": "tsx scripts/build-fts-sql.ts",
    "sync-fts": "pnpm build:fts-sql && wrangler d1 execute til --remote --file=public/fts.sql",
    "sync-fts:local": "pnpm build:fts-sql && wrangler d1 execute til --local --file=public/fts.sql",
    "vrt": "playwright test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
  "proxy": "http://localhost:8081/",
  "msw": {
    "workerDirectory": "static"
  },
  "packageManager": "pnpm@11.10.0"
}
